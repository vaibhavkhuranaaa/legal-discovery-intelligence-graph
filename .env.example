# Legal Discovery Intelligence Graph — environment template.
# Copy to `.env` and fill in values. Never commit `.env`.

# PostgreSQL + pgvector (Supabase connection string, e.g. postgresql://user:pass@host:6543/postgres)
# When pasting from the Supabase dashboard, replace [YOUR-PASSWORD] entirely —
# the square brackets are template markers, not part of the password.
DATABASE_URL=

# Neo4j AuraDB
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Embeddings (default model used if unset)
EMBEDDING_MODEL_NAME=

# Application
APP_ENV=
LOG_LEVEL=
